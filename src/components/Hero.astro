---
const { className = "" } = Astro.props;
---

<svg
  class={"poly-accent " + className}
  viewBox="0 0 1200 700"
  preserveAspectRatio="xMidYMid slice"
  aria-hidden="true"
>
  <defs>
    <!-- fade/mask so it blends into background -->
    <radialGradient id="fade" cx="18%" cy="18%" r="78%">
      <stop offset="0%" stop-color="#000" />
      <stop offset="52%" stop-color="#000" />
      <stop offset="78%" stop-color="transparent" />
      <stop offset="100%" stop-color="transparent" />
    </radialGradient>
    <mask id="m">
      <rect width="1200" height="700" fill="url(#fade)" />
    </mask>

    <!-- subtle moving light -->
    <radialGradient id="spot" cx="0" cy="0" r="1">
      <stop offset="0" stop-color="rgba(140,230,255,0.55)"/>
      <stop offset="0.35" stop-color="rgba(70,170,235,0.22)"/>
      <stop offset="0.75" stop-color="rgba(0,0,0,0)"/>
    </radialGradient>
  </defs>

  <g mask="url(#m)">
    <!-- BIG SHAPES (like your image) -->
    <polygon points="0,0 540,0 310,210" fill="#1f8fd6" opacity="0.85"/>
    <polygon points="540,0 930,110 700,310" fill="#1577b8" opacity="0.82"/>
    <polygon points="0,0 310,210 0,430" fill="#0e4e7b" opacity="0.92"/>
    <polygon points="310,210 700,310 520,520" fill="#0f5f93" opacity="0.85"/>
    <polygon points="0,430 520,520 240,700" fill="#0b2e4a" opacity="0.95"/>

    <!-- INNER FACETS -->
    <polygon points="320,90 560,40 480,220" fill="#6fd0ff" opacity="0.30"/>
    <polygon points="560,40 840,90 720,240" fill="#bfeeff" opacity="0.18"/>
    <polygon points="480,220 720,240 610,420" fill="#d7f6ff" opacity="0.14"/>

    <!-- DIAGONAL SLAB (gives that “slice” look) -->
    <polygon points="160,310 980,210 1080,320 260,430" fill="#74cfff" opacity="0.16"/>
    <polygon points="210,360 820,290 920,360 310,470" fill="#0a2237" opacity="0.22"/>

    <!-- RIGHT EDGE DARK PLANE -->
    <polygon points="930,110 1200,0 1200,380 980,210" fill="#08243b" opacity="0.90"/>

    <!-- SUBTLE SPOTLIGHT (animated via CSS) -->
    <g class="poly-accent__spot">
      <circle cx="260" cy="210" r="420" fill="url(#spot)"/>
    </g>
  </g>
</svg>

<style>
.poly-accent{
  width: 100%;
  height: 100%;
  display:block;
}
.poly-accent__spot{
  mix-blend-mode: screen;
  opacity: .85;
  transform-origin: 0 0;
  animation: polyDrift 10s ease-in-out infinite;
}
@keyframes polyDrift{
  0%{ transform: translate(-20px, -10px); }
  50%{ transform: translate(35px, 18px); }
  100%{ transform: translate(-20px, -10px); }
}
@media (prefers-reduced-motion: reduce){
  .poly-accent__spot{ animation: none; }
}
</style>
