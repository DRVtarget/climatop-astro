---
const {
  title = "Air Conditioning.\nDone Properly.",
  subtitle = "Installation, heat pumps & maintenance for Costa Blanca homes. Clean finish, transparent pricing, fast response.",
  primaryCta = { label: "Book Free Visit", href: "#contact" },
  secondaryCta = { label: "Call Now", href: "tel:+34600000000" },
  kicker = "Costa Blanca • Torrevieja • Orihuela Costa",
} = Astro.props;
---

<section class="hero" data-hero>
  <!-- Background -->
  <div class="bg" aria-hidden="true">
    <svg class="bg__svg" viewBox="0 0 1200 700" preserveAspectRatio="xMidYMid slice">
      <defs>
        <!-- Soft grain -->
        <filter id="grain">
          <feTurbulence type="fractalNoise" baseFrequency="0.75" numOctaves="2" stitchTiles="stitch" />
          <feColorMatrix type="saturate" values="0" />
          <feComponentTransfer>
            <feFuncA type="table" tableValues="0 0.08" />
          </feComponentTransfer>
        </filter>

        <!-- Highlight gradient (spotlight) -->
        <radialGradient id="spot" cx="50%" cy="40%" r="60%">
          <stop offset="0%" stop-color="rgba(120, 210, 255, 0.55)" />
          <stop offset="35%" stop-color="rgba(40, 150, 220, 0.25)" />
          <stop offset="70%" stop-color="rgba(10, 40, 70, 0.05)" />
          <stop offset="100%" stop-color="rgba(0, 0, 0, 0)" />
        </radialGradient>

        <!-- Deep vignette -->
        <radialGradient id="vignette" cx="50%" cy="45%" r="80%">
          <stop offset="0%" stop-color="rgba(0,0,0,0)" />
          <stop offset="65%" stop-color="rgba(0,0,0,0.10)" />
          <stop offset="100%" stop-color="rgba(0,0,0,0.55)" />
        </radialGradient>
      </defs>

      <!-- Base -->
      <rect width="1200" height="700" fill="#061a2b" />

      <!-- Low-poly layer (generated by JS) -->
      <g class="poly" data-poly></g>

      <!-- Subtle moving spotlight -->
      <g class="light" data-light>
        <circle cx="600" cy="280" r="420" fill="url(#spot)" />
      </g>

      <!-- Vignette + grain -->
      <rect width="1200" height="700" fill="url(#vignette)" />
      <rect width="1200" height="700" filter="url(#grain)" opacity="0.8" />
    </svg>

    <!-- Extra glow + shimmer -->
    <div class="bg__glow" data-glow></div>
    <div class="bg__shimmer"></div>
  </div>

  <!-- Content -->
  <div class="content">
    <p class="kicker">{kicker}</p>
    <h1 class="h1">{title}</h1>
    <p class="lead">{subtitle}</p>

    <div class="cta">
      <a class="btn btn--primary" href={primaryCta.href}>{primaryCta.label}</a>
      <a class="btn btn--ghost" href={secondaryCta.href}>{secondaryCta.label}</a>
    </div>

    <div class="meta">
      <span class="pill">Certified brands</span>
      <span class="pill">Same-week installation</span>
      <span class="pill">English-speaking team</span>
    </div>
  </div>

  <!-- Small bottom fade -->
  <div class="fade" aria-hidden="true"></div>
</section>

<script is:inline>
  // Ultra low-poly background generator + parallax spotlight
  (() => {
    const hero = document.querySelector('[data-hero]');
    if (!hero) return;

    const polyGroup = hero.querySelector('[data-poly]');
    const light = hero.querySelector('[data-light] circle');
    const glow = hero.querySelector('[data-glow]');

    // Respect reduced motion
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Helpers
    const rand = (a, b) => a + Math.random() * (b - a);
    const clamp = (v, a, b) => Math.max(a, Math.min(b, v));
    const lerp = (a, b, t) => a + (b - a) * t;

    // Colors (tweak to match your brand)
    const palette = [
      '#0b2a45', '#0d3a60', '#0e4f7d', '#0f5d92',
      '#1176b1', '#0a3b63', '#0c2440', '#134e7e'
    ];

    // Build random triangles using a jittered grid (fast & looks "low-poly")
    function generatePolys() {
      // Clear
      while (polyGroup.firstChild) polyGroup.removeChild(polyGroup.firstChild);

      const W = 1200, H = 700;
      const step = 120;        // bigger = fewer polygons
      const jitter = 55;       // randomness

      // Points grid
      const pts = [];
      for (let y = -step; y <= H + step; y += step) {
        for (let x = -step; x <= W + step; x += step) {
          pts.push({
            x: x + rand(-jitter, jitter),
            y: y + rand(-jitter, jitter)
          });
        }
      }

      // Convert to indexed rows/cols
      const cols = Math.round((W + 2*step) / step) + 1;
      const rows = Math.round((H + 2*step) / step) + 1;

      // Triangulate each cell into 2 triangles (random diagonal)
      const frag = document.createDocumentFragment();
      for (let r = 0; r < rows - 1; r++) {
        for (let c = 0; c < cols - 1; c++) {
          const i = r * cols + c;
          const p00 = pts[i];
          const p10 = pts[i + 1];
          const p01 = pts[i + cols];
          const p11 = pts[i + cols + 1];

          const diag = Math.random() > 0.5;

          const tris = diag
            ? [[p00, p10, p11], [p00, p11, p01]]
            : [[p00, p10, p01], [p10, p11, p01]];

          for (const t of tris) {
            const poly = document.createElementNS('http://www.w3.org/2000/svg', 'polygon');
            poly.setAttribute('points', `${t[0].x},${t[0].y} ${t[1].x},${t[1].y} ${t[2].x},${t[2].y}`);

            // Depth shading based on centroid
            const cx = (t[0].x + t[1].x + t[2].x) / 3;
            const cy = (t[0].y + t[1].y + t[2].y) / 3;
            const nx = cx / W;
            const ny = cy / H;

            // pick a palette color and adjust opacity by position
            const color = palette[Math.floor(rand(0, palette.length))];
            const op = clamp(0.28 + (0.22 * (1 - ny)) + (0.12 * (nx - 0.5)), 0.18, 0.62);

            poly.setAttribute('fill', color);
            poly.setAttribute('opacity', String(op));
            poly.classList.add('poly__tri');

            frag.appendChild(poly);
          }
        }
      }
      polyGroup.appendChild(frag);
    }

    generatePolys();

    // Re-generate on resize (debounced)
    let resizeT = 0;
    window.addEventListener('resize', () => {
      window.clearTimeout(resizeT);
      resizeT = window.setTimeout(() => generatePolys(), 180);
    });

    if (prefersReduced) return;

    // Parallax + spotlight follow
    let targetX = 0.5, targetY = 0.4;  // normalized
    let currX = targetX, currY = targetY;

    function setTargetFromEvent(e) {
      const rect = hero.getBoundingClientRect();
      const x = (e.clientX - rect.left) / rect.width;
      const y = (e.clientY - rect.top) / rect.height;
      targetX = clamp(x, 0, 1);
      targetY = clamp(y, 0, 1);
    }

    hero.addEventListener('pointermove', setTargetFromEvent, { passive: true });

    // Gentle idle motion when no mouse movement
    let t0 = performance.now();
    function tick(now) {
      const dt = Math.min(0.05, (now - t0) / 1000);
      t0 = now;

      // Ease
      currX = lerp(currX, targetX, 1 - Math.pow(0.001, dt));
      currY = lerp(currY, targetY, 1 - Math.pow(0.001, dt));

      // Idle drift
      const time = now * 0.00025;
      const driftX = 0.02 * Math.sin(time);
      const driftY = 0.02 * Math.cos(time * 1.12);

      const x = clamp(currX + driftX, 0, 1);
      const y = clamp(currY + driftY, 0, 1);

      // Spotlight position in SVG coords
      const sx = 1200 * x;
      const sy = 700 * y;

      light.setAttribute('cx', String(sx));
      light.setAttribute('cy', String(sy));

      // Background glow (CSS layer)
      glow.style.setProperty('--mx', (x * 100).toFixed(2) + '%');
      glow.style.setProperty('--my', (y * 100).toFixed(2) + '%');

      // Parallax on polygons group
      const px = (x - 0.5) * 18;   // px
      const py = (y - 0.5) * 12;
      polyGroup.style.transform = `translate(${px}px, ${py}px)`;

      requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  })();
</script>

<style>
.hero{
  position: relative;
  min-height: 92vh;
  display: grid;
  place-items: center;
  overflow: hidden;
  color: #eef7ff;
}

.bg{
  position:absolute;
  inset:0;
  z-index:0;
}

.bg__svg{
  width:100%;
  height:100%;
  display:block;
  transform: scale(1.02);
}

.poly{
  transform-origin: 50% 50%;
  transition: transform 120ms ease;
}

.poly__tri{
  mix-blend-mode: screen;
}

.light{
  mix-blend-mode: screen;
  opacity: 0.92;
}

.bg__glow{
  position:absolute;
  inset:0;
  pointer-events:none;
  background:
    radial-gradient(500px 380px at var(--mx, 50%) var(--my, 40%),
      rgba(130, 220, 255, 0.25),
      rgba(60, 160, 230, 0.12) 45%,
      rgba(0, 0, 0, 0) 70%);
  filter: blur(2px);
  opacity: 0.95;
}

.bg__shimmer{
  position:absolute;
  inset:-30%;
  pointer-events:none;
  background:
    linear-gradient(115deg,
      rgba(255,255,255,0) 35%,
      rgba(120,220,255,0.08) 50%,
      rgba(255,255,255,0) 65%);
  transform: translateX(-20%);
  animation: shimmer 8s linear infinite;
  mix-blend-mode: screen;
  opacity: 0.65;
}

@keyframes shimmer{
  0%{ transform: translateX(-35%) rotate(0.001deg); }
  100%{ transform: translateX(35%) rotate(0.001deg); }
}

.content{
  position: relative;
  z-index: 2;
  width: min(980px, 92vw);
  padding: 88px 28px 64px;
}

.kicker{
  font-size: 14px;
  letter-spacing: .12em;
  text-transform: uppercase;
  opacity: .85;
  margin: 0 0 12px;
}

.h1{
  font-size: clamp(40px, 5vw, 64px);
  line-height: 1.04;
  white-space: pre-line;
  margin: 0 0 14px;
}

.lead{
  font-size: clamp(16px, 1.5vw, 18px);
  line-height: 1.6;
  max-width: 62ch;
  opacity: .9;
  margin: 0 0 26px;
}

.cta{
  display:flex;
  gap: 12px;
  flex-wrap: wrap;
  margin: 0 0 22px;
}

.btn{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  gap:10px;
  padding: 12px 18px;
  border-radius: 14px;
  text-decoration:none;
  font-weight: 700;
  letter-spacing: .01em;
  transition: transform .15s ease, background .15s ease, border-color .15s ease;
  will-change: transform;
}

.btn--primary{
  background: rgba(120, 220, 255, 0.18);
  border: 1px solid rgba(140, 230, 255, 0.35);
  color: #f2fbff;
  box-shadow: 0 18px 60px rgba(0,0,0,.35);
}

.btn--ghost{
  background: rgba(0,0,0,0.18);
  border: 1px solid rgba(255,255,255,0.18);
  color:#f2fbff;
}

.btn:hover{
  transform: translateY(-1px);
}

.meta{
  display:flex;
  gap: 10px;
  flex-wrap: wrap;
}

.pill{
  font-size: 13px;
  padding: 8px 12px;
  border-radius: 999px;
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.12);
  backdrop-filter: blur(6px);
}

.fade{
  position:absolute;
  left:0; right:0; bottom:0;
  height: 120px;
  z-index: 1;
  background: linear-gradient(to bottom, rgba(6,26,43,0), rgba(6,26,43,1));
}
</style>
