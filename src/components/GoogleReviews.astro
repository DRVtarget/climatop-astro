---
type Review = { author: string; rating: number | null; when: string | null; text: string; time: number | null };

let data: any = null;
let error: string | null = null;

try {
  const res = await fetch(new URL("/api/reviews.json", Astro.url));
  data = await res.json();
  if (data?.error) error = data.error;
} catch (e: any) {
  error = "Failed to load reviews.";
}

const rating = data?.rating;
const totalReviews = data?.totalReviews;
const reviews: Review[] = Array.isArray(data?.reviews) ? data.reviews : [];
const googleUrl = data?.googleUrl || "https://www.google.com/search?q=Climatop+Air+Conditioning+Torrevieja+reviews";
const businessName = data?.name || "Climatop";
---

<section id="reviews" class="border-t border-slate-200/70 bg-white">
  <div class="mx-auto max-w-6xl px-4 py-20">
    <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
      <div class="max-w-2xl">
        <h2 class="text-3xl font-semibold tracking-tight text-slate-900">Google Reviews</h2>
        <p class="mt-3 text-base text-slate-600">
          Real reviews from Google Business Profile.
        </p>

        {rating && totalReviews && (
          <p class="mt-4 inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white px-3 py-1 text-sm font-semibold text-slate-700">
            <span aria-hidden="true">⭐</span>
            <span>{rating} / 5</span>
            <span class="text-slate-400">•</span>
            <span>{totalReviews} reviews</span>
          </p>
        )}
      </div>

      <div>
        <a
          class="inline-flex items-center justify-center rounded-xl border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-900 hover:bg-slate-50"
          href={googleUrl}
          target="_blank"
          rel="noreferrer"
        >
          View on Google
        </a>
      </div>
    </div>

    {error ? (
      <p class="mt-10 text-sm text-slate-600">{error}</p>
    ) : (
      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {reviews.slice(0, 3).map((r) => (
          <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="flex items-center justify-between">
              <p class="text-sm font-semibold text-slate-900">{r.author}</p>
              <p class="text-xs text-slate-500">{r.when}</p>
            </div>
            <p class="mt-3 text-sm text-slate-600">
              {r.text && r.text.length > 220 ? r.text.slice(0, 220) + "…" : r.text}
            </p>
            {r.rating !== null && (
              <p class="mt-4 text-xs font-semibold text-slate-700">⭐ {r.rating} / 5</p>
            )}
          </article>
        ))}
      </div>
    )}

    {rating && totalReviews && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "name": businessName,
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": rating,
          "reviewCount": totalReviews
        }
      })}></script>
    )}
  </div>
</section>
