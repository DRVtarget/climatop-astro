---
const {
  kicker = "Costa Blanca • Torrevieja • Orihuela Costa",
  title = "Air Conditioning Installation\nDone Clean. Done Right.",
  subtitle = "Certified installation, heat pumps & maintenance for Costa Blanca homes. Clean finish, transparent pricing, fast response.",
  primaryCta = { label: "Book Free Home Visit", href: "#contact" },
  secondaryCta = { label: "Call / WhatsApp", href: "tel:+34600000000" },
  proofs = ["English-speaking team", "Same-week installation", "Certified brands"],
  badges = ["Licensed installers", "Warranty-backed work", "Clean pipework finish"],
} = Astro.props;

const titleLines = String(title).split("\n");
---

<section class="relative overflow-hidden js-hero">
  <!-- soft premium background -->
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute -top-24 right-[-120px] h-[420px] w-[420px] rounded-full bg-slate-200/60 blur-3xl"></div>
    <div class="absolute -bottom-24 left-[-140px] h-[460px] w-[460px] rounded-full bg-slate-100 blur-3xl"></div>
  </div>

  <div class="mx-auto max-w-6xl px-4 py-16 md:py-24">
    <div class="grid items-center gap-10 md:grid-cols-2">
      <!-- Left -->
      <div>
        <div class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white/70 px-3 py-1 text-xs font-semibold text-slate-600 js-hero-kicker">
          <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
          <span>{kicker}</span>
        </div>

        <h1 class="mt-5 text-4xl font-semibold tracking-tight text-slate-900 md:text-6xl js-hero-title">
          {titleLines.map((line) => (
            <span class="block">{line}</span>
          ))}
        </h1>

        <p class="mt-5 max-w-xl text-lg leading-relaxed text-slate-600 js-hero-subtitle">
          {subtitle}
        </p>

        <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center js-hero-cta">
          <a
            class="inline-flex items-center justify-center rounded-2xl bg-slate-900 px-6 py-3 text-sm font-semibold !text-white shadow-sm hover:bg-slate-800"
            href={primaryCta.href}
          >
            {primaryCta.label}
          </a>

          <a
            class="inline-flex items-center justify-center rounded-2xl border border-slate-300 bg-white px-6 py-3 text-sm font-semibold text-slate-900 hover:bg-slate-50"
            href={secondaryCta.href}
          >
            {secondaryCta.label}
          </a>
        </div>

        <ul class="mt-6 flex flex-wrap gap-2 text-sm text-slate-600">
          {proofs.map((p) => (
            <li class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white px-3 py-1">
              <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
              <span>{p}</span>
            </li>
          ))}
        </ul>

        <div class="mt-8 grid gap-3 sm:grid-cols-3">
          {badges.map((b) => (
            <div class="rounded-2xl border border-slate-200 bg-white/80 p-4 text-sm font-medium text-slate-800 shadow-sm">
              {b}
            </div>
          ))}
        </div>
      </div>

      <!-- Right -->
      <div class="relative js-hero-card">
        <div class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm">
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="text-xs font-semibold text-slate-500">FREE ON-SITE VISIT</p>
              <p class="mt-2 text-lg font-semibold text-slate-900">
                Get a clean, certified installation — without surprises.
              </p>
              <p class="mt-2 text-sm text-slate-600">
                We assess your home, recommend the right unit, and provide a clear written quote.
              </p>
            </div>

            <div class="rounded-2xl border border-slate-200 bg-slate-50 px-3 py-2 text-xs font-semibold text-slate-700">
              24–48h reply
            </div>
          </div>

          <div class="mt-6 grid grid-cols-2 gap-3">
            {["Fast response", "Clean finish", "Transparent pricing", "Aftercare"].map((t) => (
              <div class="rounded-2xl border border-slate-200 bg-white p-4 text-sm font-medium text-slate-700">
                {t}
              </div>
            ))}
          </div>

          <div class="mt-6 rounded-2xl border border-slate-200 bg-slate-50 p-4">
            <p class="text-xs font-semibold text-slate-500">MOST REQUESTED</p>
            <div class="mt-3 flex flex-wrap gap-2">
              {["Split A/C", "Multi-split", "Heat pumps", "Maintenance"].map((t) => (
                <span class="rounded-full border border-slate-200 bg-white px-3 py-1 text-xs font-semibold text-slate-700">
                  {t}
                </span>
              ))}
            </div>
          </div>
        </div>

        <div class="pointer-events-none absolute -inset-8 -z-10 rounded-[2.5rem] bg-gradient-to-r from-slate-100 to-white blur-2xl"></div>
      </div>
    </div>
  </div>
</section>

<script type="module">
  // Premium, lightweight reveal (loads GSAP only when hero is visible)
  const hero = document.querySelector(".js-hero");
  const reduce = window.matchMedia?.("(prefers-reduced-motion: reduce)")?.matches;
  if (hero && !reduce) {
    const run = async () => {
      const mod = await import("gsap");
      const gsap = mod.default;

      const tl = gsap.timeline({ defaults: { ease: "power3.out" } });
      tl.from(".js-hero-kicker", { y: 10, opacity: 0, duration: 0.35 })
        .from(".js-hero-title", { y: 18, opacity: 0, duration: 0.55 }, "-=0.15")
        .from(".js-hero-subtitle", { y: 14, opacity: 0, duration: 0.45 }, "-=0.20")
        .from(".js-hero-cta", { y: 10, opacity: 0, duration: 0.40 }, "-=0.20")
        .from(".js-hero-card", { y: 14, opacity: 0, duration: 0.55 }, "-=0.35");
    };

    const io = new IntersectionObserver(
      (entries) => {
        if (entries.some((e) => e.isIntersecting)) {
          io.disconnect();
          run();
        }
      },
      { threshold: 0.25 }
    );

    io.observe(hero);
  }
</script>
