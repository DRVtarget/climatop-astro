---
import "../styles/global.css";

const {
  title = "Climatop • Air Conditioning Costa Blanca",
  description = "Installation, heat pumps & maintenance for Costa Blanca homes. Clean finish, transparent pricing, fast response.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>

  <body class="min-h-screen bg-white text-slate-900">
    <header class="sticky top-0 z-50 border-b border-slate-200/70 bg-white/80 backdrop-blur">
      <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3">
        <a href="/" class="group flex items-center gap-2 font-semibold tracking-tight">
          <span
            class="inline-flex h-9 w-9 items-center justify-center rounded-xl bg-slate-900 !text-white shadow-sm transition group-hover:bg-slate-800"
          >
            C
          </span>
          <span class="text-slate-900">Climatop</span>
        </a>

        <nav class="hidden items-center gap-6 text-sm font-medium text-slate-600 md:flex">
          <a class="transition hover:text-slate-900" href="#services">Services</a>
          <a class="transition hover:text-slate-900" href="#reviews">Reviews</a>
          <a class="transition hover:text-slate-900" href="#contact">Contact</a>
        </nav>

        <div class="flex items-center gap-2">
          <a
            class="hidden rounded-xl border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-900 transition hover:bg-slate-50 md:inline-flex"
            href="tel:+34600000000"
          >
            Call
          </a>

          <a
            class="inline-flex items-center justify-center rounded-xl bg-slate-900 px-4 py-2 text-sm font-semibold !text-white shadow-sm transition hover:bg-slate-800"
            href="#contact"
          >
            Book Free Home Visit
          </a>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="border-t border-slate-200/70">
      <div class="mx-auto max-w-6xl px-4 py-10 text-sm text-slate-600">
        <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
          <p>© {new Date().getFullYear()} Climatop. All rights reserved.</p>
          <p>Torrevieja • Orihuela Costa • Costa Blanca</p>
        </div>
      </div>
    </footer>
  </body>
</html>