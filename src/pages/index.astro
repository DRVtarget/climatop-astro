---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import GoogleReviews from "../components/GoogleReviews.astro";
---

<Layout
  title="Climatop • Air Conditioning Costa Blanca"
  description="Installation, heat pumps & maintenance for Costa Blanca homes. Clean finish, transparent pricing, fast response."
>
  <Hero />

<!-- Services -->
<section id="services" class="border-t border-slate-200/70 bg-white">
  <div class="mx-auto max-w-6xl px-4 py-20">

    <div class="max-w-2xl">
      <h2 class="text-3xl font-semibold tracking-tight text-slate-900">
        Professional Air Conditioning Services
      </h2>

      <p class="mt-4 text-base text-slate-600">
        Installation, maintenance and heat pump solutions across 
        Costa Blanca — delivered cleanly, documented properly, 
        and backed by warranty.
      </p>
    </div>

    <div class="mt-14 grid gap-8 md:grid-cols-3">

      <!-- Card 1 -->
      <article class="group rounded-2xl border border-slate-200 bg-white p-7 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg">

        <h3 class="text-lg font-semibold text-slate-900">
          Split & Multi-Split Installation
        </h3>

        <p class="mt-3 text-sm leading-relaxed text-slate-600">
          Correct sizing, optimal placement, clean pipe routing and 
          full system commissioning.
        </p>

        <p class="mt-5 text-xs font-medium text-slate-500">
          ✔ Clean finish • ✔ Certified brands • ✔ Same-week installation
        </p>

      </article>

      <!-- Card 2 -->
      <article class="group rounded-2xl border border-slate-200 bg-white p-7 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg">

        <h3 class="text-lg font-semibold text-slate-900">
          Heat Pump Installation & Setup
        </h3>

        <p class="mt-3 text-sm leading-relaxed text-slate-600">
          Energy-efficient heating and hot water solutions 
          tailored for Costa Blanca homes.
        </p>

        <p class="mt-5 text-xs font-medium text-slate-500">
          ✔ Optimized performance • ✔ Warranty-backed • ✔ Long-term reliability
        </p>

      </article>

      <!-- Card 3 -->
      <article class="group rounded-2xl border border-slate-200 bg-white p-7 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg">

        <h3 class="text-lg font-semibold text-slate-900">
          Maintenance & Diagnostics
        </h3>

        <p class="mt-3 text-sm leading-relaxed text-slate-600">
          Seasonal servicing, leak detection, system checks 
          and performance optimization.
        </p>

        <p class="mt-5 text-xs font-medium text-slate-500">
          ✔ Fast response • ✔ Transparent pricing • ✔ Aftercare support
        </p>

      </article>

    </div>

  </div>
  <!-- Reviews -->
 <GoogleReviews /> 
<section id="reviews" class="border-t border-slate-200/70 bg-slate-50/60">
  <div class="mx-auto max-w-6xl px-4 py-20">

    <div class="flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between">
      <div class="max-w-2xl">
        <h2 class="text-3xl font-semibold tracking-tight text-slate-900">
          Google Reviews
        </h2>

        <p class="mt-4 text-base text-slate-600">
          Real feedback from homeowners across Costa Blanca.
        </p>

        <div class="mt-5 inline-flex items-center gap-3 rounded-2xl border border-slate-200 bg-white px-4 py-2 shadow-sm">
          <span class="text-sm font-semibold text-slate-900">4.9</span>
          <span class="text-sm text-slate-500">/ 5</span>
          <span class="text-sm text-slate-400">•</span>
          <span class="text-sm font-semibold text-slate-900">87</span>
          <span class="text-sm text-slate-500">reviews</span>
        </div>
      </div>

      <a
        class="inline-flex items-center justify-center rounded-xl border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-900 hover:bg-slate-50"
        href="#"
      >
        View on Google
      </a>
    </div>

    <div class="mt-12 grid gap-8 md:grid-cols-3">
      {[
        "Clean installation and great finish.",
        "Transparent pricing and no surprises.",
        "Fast and reliable service."
      ].map((text) => (
        <article class="rounded-2xl border border-slate-200 bg-white p-7 shadow-sm">
          <p class="text-xs font-semibold text-slate-500">★★★★★</p>
          <p class="mt-3 text-sm text-slate-600">{text}</p>
        </article>
      ))}
    </div>

  </div>
</section>
</section>

  <!-- Contact -->
  <section id="contact" class="border-t border-slate-200/70 bg-white">
    <div class="mx-auto max-w-6xl px-4 py-16">
      <div class="grid gap-10 md:grid-cols-2">
        <div>
          <h2 class="text-2xl font-semibold tracking-tight text-slate-900">Contact</h2>
          <p class="mt-2 max-w-prose text-sm text-slate-600">
            Send a quick message and we’ll reply within 24–48 hours. Or call / WhatsApp for faster response.
          </p>

          <div class="mt-6 flex flex-wrap gap-2">
            <a class="inline-flex rounded-xl bg-slate-900 px-4 py-2 text-sm font-semibold !text-white hover:bg-slate-800" href="tel:+34600000000">
              Call / WhatsApp
            </a>
            <a class="inline-flex rounded-xl border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-900 hover:bg-slate-50" href="#services">
              View Services
            </a>
          </div>

          <p class="mt-8 text-sm text-slate-600">Torrevieja • Orihuela Costa • Costa Blanca</p>
        </div>

        <form class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <div class="grid gap-4">
            <label class="grid gap-1 text-sm font-medium text-slate-900">
              Name
              <input class="rounded-xl border border-slate-300 px-3 py-2 text-sm outline-none focus:ring-2 focus:ring-slate-200" type="text" name="name" />
            </label>

            <label class="grid gap-1 text-sm font-medium text-slate-900">
              Phone / WhatsApp
              <input class="rounded-xl border border-slate-300 px-3 py-2 text-sm outline-none focus:ring-2 focus:ring-slate-200" type="tel" name="phone" />
            </label>

            <label class="grid gap-1 text-sm font-medium text-slate-900">
              What do you need?
              <textarea class="min-h-[110px] rounded-xl border border-slate-300 px-3 py-2 text-sm outline-none focus:ring-2 focus:ring-slate-200" name="message"></textarea>
            </label>

            <button class="inline-flex items-center justify-center rounded-xl bg-slate-900 px-4 py-2 text-sm font-semibold !text-white hover:bg-slate-800" type="submit">
              Send Message
            </button>

            <p class="text-xs text-slate-500">
              (Form handling will be added later — for now this is UI only.)
            </p>
          </div>
        </form>
      </div>
    </div>
  </section>
</Layout>
